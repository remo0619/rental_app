<%= render "shared/flash_message" %>

<div class="container mt-4" style="max-width: 600px;">
  <div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom-0 pt-4 d-flex justify-content-between align-items-center">
      <h1 class="h3 mb-0 text-secondary fw-bold">機器詳細</h1>
      <% color = @device.available? ? 'primary' : (@device.borrowed? ? 'success' : 'danger') %>
      <span class="badge rounded-pill bg-<%= color %>-subtle text-<%= color %> border border-<%= color %>-subtle px-3 py-2">
      <%= @device.status_i18n %>
      </span>
    </div>
    <div class="card-body p-4">
      <div class="mb-4">
        <label class="form-label text-muted small text-uppercase mb-1">デバイスの種類</label>
        <div class="fs-5 fw-bold text-dark">
          <%= @device.device_type %>
        </div>
      </div>
      
      <div class="mb-4">
        <label class="form-label text-muted small text-uppercase mb-1">シリアル番号</label>
        <div class="fs-5 fw-bold text-dark">
          <%= @device.serial %>
        </div>
      </div>

      <hr class="my-4 text-light">

      <div class="d-grid gap-2">
        <% if current_user.admin? %>
          <%= link_to "機器情報編集", edit_device_path(@device), class: "btn btn-primary" %>
        <% end %>
        <% if @device.available? %>
          <%= link_to "この機器を利用する", new_request_path(device_id: @device.id), class: "btn btn-success" %>
        <% elsif @device.borrowed? && @my_request.present? %>
          <%= button_tag "この機器を返却する", 
              type: "button", 
              class: "btn btn-danger",
              data: { 
                bs_toggle: "modal", 
                bs_target: "#confirmModal",
                bs_url: return_request_path(@my_request),
                bs_title: "返却確認",
                bs_message: "この機器を【返却】します。よろしいですか？"
              } %>
        <% end %>
        <%= link_to "戻る", :back, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>

<%= render "shared/confirm_modal" %>

