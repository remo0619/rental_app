<div class="container mt-5" style="max-width: 450px;">
  <div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom-0 pt-4 text-center">
      <h1 class="h3 mb-0 text-secondary fw-bold">パスワード再設定</h1>
    </div>

    <div class="card-body p-4">
      <p class="text-muted small mb-4">
        ご登録のメールアドレスを入力してください。
      </p>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <% # 全体エラーメッセージ（必要に応じて） %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <% # メールアドレス %>
        <div class="mb-4">
          <%= f.label :email, class: "form-label text-muted small text-uppercase mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                            class: "form-control", placeholder: "example@mail.com" %>
          
          <% if resource.errors[:email].any? %>
            <div class="text-danger small mt-1">
              <%= resource.errors.full_messages_for(:email).first %>
            </div>
          <% end %>
        </div>

        <div class="d-grid gap-2 mb-3">
          <%= f.submit "再設定メールを送信する", class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>

      <div class="text-center small">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>