<div class="container mt-5" style="max-width: 500px;">
  <div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom-0 pt-4 text-center">
      <h1 class="h3 mb-0 text-secondary fw-bold">新規登録</h1>
    </div>

    <div class="card-body p-4">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

        <% # 名前 %>
        <div class="mb-3">
          <%= f.label :name, class: "form-label text-muted small text-uppercase mb-1" %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "form-control #{'is-invalid' if resource.errors[:name].any?}" %>
          <% if resource.errors[:name].any? %>
            <div class="text-danger small mt-1">
              <%= resource.errors.full_messages_for(:name).first %>
            </div>
          <% end %>
        </div>

        <% # メールアドレス %>
        <div class="mb-3">
          <%= f.label :email, class: "form-label text-muted small text-uppercase mb-1" %>
          <%= f.email_field :email, autocomplete: "email", class: "form-control #{'is-invalid' if resource.errors[:email].any?}" %>
          <% if resource.errors[:email].any? %>
            <div class="text-danger small mt-1">
              <%= resource.errors.full_messages_for(:email).first %>
            </div>
          <% end %>
        </div>

        <% # パスワード %>
        <div class="mb-3">
          <div class="d-flex justify-content-between align-items-end mb-1">
            <%= f.label :password, class: "form-label text-muted small text-uppercase mb-0" %>
            <% if @minimum_password_length %>
              <span class="text-muted" style="font-size: 0.75rem;">
                （<%= @minimum_password_length %>文字以上）
              </span>
            <% end %>
          </div>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control #{'is-invalid' if resource.errors[:password].any?}" %>
          <% if resource.errors[:password].any? %>
            <div class="text-danger small mt-1">
              <%= resource.errors.full_messages_for(:password).first %>
            </div>
          <% end %>
        </div>

        <% # パスワード（確認用） %>
        <div class="mb-4">
          <%= f.label :password_confirmation, class: "form-label text-muted small text-uppercase mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control #{'is-invalid' if resource.errors[:password_confirmation].any?}" %>
          <% if resource.errors[:password_confirmation].any? %>
            <div class="text-danger small mt-1">
              <%= resource.errors.full_messages_for(:password_confirmation).first %>
            </div>
          <% end %>
        </div>

        <% # 登録ボタン %>
        <div class="d-grid gap-2 mb-3">
          <%= f.submit "アカウント作成", class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>

      <% # 既存のリンク %>
      <div class="text-center small">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>