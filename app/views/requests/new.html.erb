<div class="container mt-4" style="max-width: 600px;">
  <div class="card shadow-sm">
    <div class="card-header bg-white py-3">
      <h1 class="h4 mb-0 text-secondary">機器利用申請</h1>
    </div>
    <div class="card-body p-4">
      <% # 機器情報 %>
      <div class="mb-4">
        <label class="form-label text-muted small text-uppercase mb-1">デバイスの種類</label>
        <div class="fs-5 fw-bold text-dark">
          <%= @device.device_type %>
        </div>
      </div>
      
      <div class="mb-4">
        <label class="form-label text-muted small text-uppercase mb-1">シリアル番号</label>
        <div class="fs-5 text-dark font-monospace">
          <%= @device.serial %>
        </div>
      </div>

      <% # 承認依頼フォーム %>
      <%= form_with model: @request do |f| %>
        <%= f.hidden_field :device_id, value: @device.id %>
        <div class="mb-4">
          <%= f.label :start_date, "利用開始日", class: "form-label fw-bold" %>
          <%= f.date_field :start_date, class: "form-control #{'is-invalid' if @request.errors[:start_date].any?}" %>
          <% if @request.errors[:start_date].any? %>
            <div class="text-danger small mt-1">
              <%= @request.errors.full_messages_for(:start_date).first %>
            </div>
          <% end %>
        </div>

        <div class="mb-4">
          <%= f.label :end_date, "利用終了日", class: "form-label fw-bold" %>
          <%= f.date_field :end_date, class: "form-control #{'is-invalid' if @request.errors[:end_date].any?}" %>
          <% if @request.errors[:end_date].any? %>
            <div class="text-danger small mt-1">
              <%= @request.errors.full_messages_for(:end_date).first %>
            </div>
          <% end %>
        </div>

        <div class="mb-3">
          <%= f.label :approver_id, "承認者" %>
          <%= f.collection_select :approver_id, @admins, :id, :name, { prompt: "管理者を選択してください" }, { class: "form-select" } %>
          <% if @request.errors[:approver_id].any? %>
            <div class="text-danger small mt-1">
              <%= @request.errors.full_messages_for(:approver_id).first %>
            </div>
          <% end %>
        </div>

        <div class="d-grid gap-2 mt-5">
          <%= f.submit "申請する", class: "btn btn-primary btn-lg" %>
          <%= link_to "機器詳細に戻る", device_path(@device), class: "btn btn-link text-decoration-none text-muted" %>
        </div>
      <% end %>
    </div>
  </div>
</div>