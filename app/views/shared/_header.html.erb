<header class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
  <div class="container-fluid">
    <%= link_to "/" do %>
      <%= image_tag "AssetFlow.png", size: "230x50", class: "ms-2" %>
    <% end%>
    
    <div class="d-flex align-items-center">
      <% if user_signed_in? %>
        <%= link_to current_user.name, user_path(current_user), class: "nav-link me-3 text-dark" %>
        <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-danger btn-sm" %>
      <% end %>
    </div>
  </div>
</header>