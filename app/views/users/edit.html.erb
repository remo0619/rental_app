<div class="container mt-4" style="max-width: 600px;">
  <div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom-0 pt-4">
      <h1 class="h3 mb-0 text-secondary fw-bold">アカウント情報編集</h1>
    </div>
    <div class="card-body p-4">
      <%= form_with model: @user do |f| %>
        <div class="mb-4">
          <%= f.label :name, "ユーザー名", class: "form-label fw-bold" %>
          <%= f.text_field :name, class: "form-control #{'is-invalid' if @user.errors[:name].any?}" %>
          <% if @user.errors[:name].any? %>
            <div class="text-danger small mt-1">
              <%= @user.errors.full_messages_for(:name).first %>
            </div>
          <% end %>
        </div>

        <div class="mb-4">
          <%= f.label :email, "メールアドレス", class: "form-label fw-bold" %>
          <%= f.email_field :email, class: "form-control #{'is-invalid' if @user.errors[:email].any?}" %>
          <% if @user.errors[:email].any? %>
            <div class="text-danger small mt-1">
              <%= @user.errors.full_messages_for(:email).first %>
            </div>
          <% end %>
        </div>

        <div class="d-grid gap-2 mt-5">
          <%= f.submit "更新", class: "btn btn-primary btn-lg" %>
          <%= link_to "マイページに戻る", user_path(current_user), class: "btn btn-link text-decoration-none text-muted" %>
        </div>
      <% end %>
    </div>
  </div>
</div>