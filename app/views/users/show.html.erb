<%= render "shared/flash_message" %>

<div class="container mt-4" style="max-width: 1200px;">
  <% #プロフィールセクション%>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4">
      <div class="d-flex align-items-center mb-3">
        <h1 class="h3 mb-0 text-secondary fw-bold">マイページ</h1>
        <% if @user.admin? %>
          <span class="badge bg-secondary ms-2">管理者権限</span>
        <% end %>
      </div>
      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label text-muted small text-uppercase mb-1">ユーザー名</label>
          <div class="fs-5 fw-bold text-dark"><%= @user.name %></div>
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label text-muted small text-uppercase mb-1">メールアドレス</label>
          <div class="fs-5 text-dark"><%= @user.email %></div>
        </div>
      </div>
      <div class="d-flex gap-2 mt-2">
        <%= link_to "編集", edit_user_path(current_user), class: "btn btn-sm btn-outline-primary" %>
        <%= link_to "パスワード変更", edit_user_registration_path(current_user), class: "btn btn-sm btn-outline-secondary" %>
      </div>
    </div>
  </div>

  <% # タブメニュー %>
  <ul class="nav nav-pills mb-3 bg-white p-2 rounded shadow-sm" id="myPageTab" role="tablist">
    <li class="nav-item me-3" role="presentation">
      <button class="nav-link active" id="borrowed_devices-tab" data-bs-toggle="pill" data-bs-target="#borrowed_devices" type="button" role="tab">利用中の機器</button>
    </li>
    <li class="nav-item me-3" role="presentation">
      <button class="nav-link" id="history-tab" data-bs-toggle="pill" data-bs-target="#history" type="button" role="tab">自分の申請履歴</button>
    </li>
    <% if @user.admin? %>
      <li class="nav-item me-3" role="presentation">
        <button class="nav-link" id="regi_devices-tab" data-bs-toggle="pill" data-bs-target="#regi_devices" type="button" role="tab">登録した機器</button>
      </li>
      <li class="nav-item me-3" role="presentation">
        <button class="nav-link position-relative" id="pending-tab" data-bs-toggle="pill" data-bs-target="#pending" type="button" role="tab">
          未承認申請
          <% if @pending_requests.any? %>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
              <%= @pending_requests.count %>
            </span>
          <% end %>
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="admin-history-tab" data-bs-toggle="pill" data-bs-target="#admin-history" type="button" role="tab">承認・否認履歴</button>
      </li>
    <% end %>
  </ul>

  <% # タブの中身 %>
  <div class="tab-content" id="myPageTabContent">
    <% # --- 自分が借りている機器の一覧タブ --- %>
    <div class="tab-pane fade show active" id="borrowed_devices" role="tabpanel">
      <div class="card shadow-sm border-0 overflow-hidden">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">種類</th>
                <th>シリアルNo</th>
                <th>利用期間</th>
                <th class="pe-4 text-end">ステータス</th>
              </tr>
            </thead>
            <tbody>
              <% if @borrowing_requests.present? %>
                <% @borrowing_requests.each do |req| %>
                  <tr class="position-relative">
                    <td class="ps-4 py-3">
                      <span class="fw-medium">
                      <%= link_to req.device.device_type, device_path(req.device), class: "text-decoration-none text-dark fw-medium stretched-link" %>
                      </span>
                    </td>
                    <td class="py-3">
                      <span class="fw-medium"><%= req.device.serial %></span>
                    </td>
                    <td class="py-3">
                      <span class="fw-medium"><%= req.start_date.strftime("%Y/%m/%d") %> ～ <%= req.end_date.strftime("%Y/%m/%d") %></span>
                    </td>
                    <td class="pe-4 py-3 text-end">
                      <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2">
                      <%= req.device.status_i18n %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="4" class="text-center py-5 text-muted">
                    <p class="text-muted mb-0">現在利用中の機器はありません。</p>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <% # --- 自分の申請履歴タブ --- %>
    <div class="tab-pane fade show" id="history" role="tabpanel">
      <div class="card shadow-sm border-0 overflow-hidden">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">申請ID</th>
                <th>種類</th>
                <th>シリアルNo</th>
                <th>利用期間</th>
                <th class="pe-4 text-end">ステータス</th>
              </tr>
            </thead>
            <tbody>
              <% if @my_requests.present? %>
                <% @my_requests.each do |req| %>
                  <tr class="position-relative">
                    <td class="ps-4 py-3">
                      <span class="fw-medium">
                      <%= link_to req.id, request_path(req), class: "text-decoration-none text-dark fw-medium stretched-link" %>
                      </span>
                    </td>
                    <td class="py-3">
                      <span class="fw-medium"><%= req.device.device_type %></span>
                    </td>
                    <td class="py-3">
                      <span class="fw-medium"><%= req.device.serial %></span>
                    </td>
                    <td class="py-3">
                      <span class="fw-medium"><%= req.start_date.strftime("%Y/%m/%d") %> ～ <%= req.end_date.strftime("%Y/%m/%d") %></span>
                    </td>
                    <td class="pe-4 py-3 text-end">
                      <% # ステータスごとの色分け %>
                      <% color = req.pending? ? 'primary' : (req.approved? ? 'success' : (req.rejected? ? 'danger' : 'secondary')) %>
                      <span class="badge rounded-pill bg-<%= color %>-subtle text-<%= color %> border border-<%= color %>-subtle px-3 py-2">
                        <%= req.status_i18n %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="5" class="text-center py-5 text-muted">
                    <p class="text-muted mb-0">申請履歴はありません。</p>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <% if @user.admin? %>
      <% # --- 登録機器一覧タブ --- %>
      <div class="tab-pane fade" id="regi_devices" role="tabpanel">
        <div class="d-flex align-items-center mb-3">
          <%= link_to "機器登録", new_device_path, class: "btn btn-sm btn-primary" %>
        </div>
        <div class="card shadow-sm border-0 overflow-hidden">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-4">種類</th>
                  <th>シリアルNo</th>
                  <th class="pe-4 text-end">ステータス</th>
                </tr>
              </thead>
              <tbody>
                <% if @devices.present? %>
                  <% @devices.each do |device| %>
                    <tr class="position-relative">
                      <td class="ps-4">
                        <%= link_to device.device_type, device_path(device), class: "text-decoration-none text-dark fw-medium stretched-link" %>
                      </td>
                      <td><%= device.serial %></td>
                      <td class="pe-4 text-end">
                        <% # ステータスごとの色分け %>
                        <% color = device.available? ? 'primary' : (device.borrowed? ? 'success' : 'danger') %>
                        <span class="badge rounded-pill bg-<%= color %>-subtle text-<%= color %> border border-<%= color %>-subtle px-3 py-2">
                          <%= device.status_i18n %>
                        </span>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr><td colspan="3" class="text-center py-5 text-muted">登録機器はありません。</td></tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <% # --- 未承認申請タブ --- %>
      <div class="tab-pane fade" id="pending" role="tabpanel">
        <div class="card shadow-sm border-0 overflow-hidden">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-4">申請ID</th>
                  <th>申請者</th>
                  <th>種類</th>
                  <th>シリアルNo</th>
                  <th>利用期間</th>
                  <th class="pe-4 text-end">ステータス</th>
                </tr>
              </thead>
              <tbody>
                <% if @pending_requests.present? %>
                  <% @pending_requests.each do |req| %>
                    <tr class="position-relative">
                      <td class="ps-4 py-3">
                        <span class="fw-medium">
                        <%= link_to req.id, show_pending_request_path(req), class: "text-decoration-none text-dark fw-medium stretched-link" %>
                        </span>
                      </td>
                      <td class="py-3">
                        <span class="fw-medium"><%= req.user.name %></span>
                      </td>
                      <td class="py-3">
                        <span class="fw-medium"><%= req.device.device_type %></span>
                      </td>
                      <td class="py-3">
                        <span class="fw-medium"><%= req.device.serial %></span>
                      </td>
                      <td class="py-3">
                        <span class="fw-medium"><%= req.start_date.strftime("%Y/%m/%d") %> ～ <%= req.end_date.strftime("%Y/%m/%d") %></span>
                      </td>
                      <td class="pe-4 py-3 text-end">
                        <span class="badge rounded-pill bg-primary-subtle text-primary border border-primary-subtle px-3 py-2">
                          <%= req.status_i18n %>
                        </span>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                      <p class="text-muted mb-0">未承認の申請はありません。</p>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <% # --- 承認履歴タブ --- %>
      <div class="tab-pane fade" id="admin-history" role="tabpanel">
        <div class="card shadow-sm border-0 overflow-hidden">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-4">申請ID</th>
                  <th>申請者</th>
                  <th>種類</th>
                  <th>シリアルNo</th>
                  <th>利用期間</th>
                  <th class="pe-4 text-end">ステータス</th>
                </tr>
              </thead>
              <tbody>
                <% if @requests_history.present? %>
                  <% @requests_history.each do |req| %>
                    <tr class="position-relative">
                      <td class="ps-4 py-3">
                        <span class="fw-medium">
                        <%= link_to req.id, show_history_request_path(req), class: "text-decoration-none text-dark fw-medium stretched-link" %>
                        </span>
                      </td>
                      <td class="py-3">
                        <span class="fw-medium"><%= req.user.name %></span>
                      </td>
                      <td class="py-3">
                        <span class="fw-medium"><%= req.device.device_type %></span>
                      </td>
                      <td class="py-3">
                        <span class="fw-medium"><%= req.device.serial %></span>
                      </td>
                      <td class="py-3">
                        <span class="fw-medium"><%= req.start_date.strftime("%Y/%m/%d") %> ～ <%= req.end_date.strftime("%Y/%m/%d") %></span>
                      </td>
                      <td class="pe-4 py-3 text-end">
                        <% # ステータスごとの色分け %>
                        <% color = req.approved? ? 'success' : (req.rejected? ? 'danger' : 'secondary') %>
                        <span class="badge rounded-pill bg-<%= color %>-subtle text-<%= color %> border border-<%= color %>-subtle px-3 py-2">
                          <%= req.status_i18n %>
                        </span>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                      <p class="text-muted mb-0">承認・否認履歴はありません。</p>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>