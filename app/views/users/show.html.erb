<div class="container mt-4" style="max-width: 600px;">
  <div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom-0 pt-4">
      <h1 class="h3 mb-0 text-secondary fw-bold">マイページ</h1>
    </div>
    <div class="card-body p-4">
      <div class="mb-4">
        <label class="form-label text-muted small text-uppercase mb-1">ユーザー名</label>
        <div class="fs-5 fw-bold text-dark">
          <%= @user.name %>
        </div>
      </div>
      
      <div class="mb-4">
        <label class="form-label text-muted small text-uppercase mb-1">メールアドレス</label>
        <div class="fs-5 text-dark">
          <%= @user.email %>
        </div>
      </div>

      <div class="mb-4">
        <label class="form-label text-muted small text-uppercase mb-1">パスワード</label>
        <div class="fs-5 text-dark">
          <p class="mb-0">********</p>
        </div>
      </div>

      <hr class="my-4 text-light">

      <div class="d-grid gap-2">
        <%= link_to "プロフィール編集", edit_user_path(current_user), class: "btn btn-primary" %>
        <%= link_to "パスワード変更", edit_user_registration_path(current_user), class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>

  <% # 管理者ユーザー表示メニュー%> 
  <% if @user.admin? %>
    <div class="d-flex justify-content-between align-items-center mb-3 mt-3">
      <h2 class="h4 mb-0 text-secondary fw-bold">登録機器一覧</h2>
      <%= link_to "機器登録", new_device_path, class: "btn btn-sm btn-outline-primary" %>
    </div>

    <div class="card shadow-sm border-0 overflow-hidden">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4 border-0 py-3">種類</th>
              <th class="border-0 py-3">シリアルNo</th>
              <th class="pe-4 border-0 py-3 text-end">ステータス</th>
            </tr>
          </thead>
          <tbody>
            <% if @devices.present? %>
              <% @devices.each do |device| %>
                <tr>
                  <td class="ps-4 py-3">
                    <span class="fw-medium"><%= device.device_type %></span>
                  </td>
                  <td class="py-3">
                    <%= link_to device.serial, device_path(device), class: "text-decoration-none fw-bold font-monospace" %>
                  </td>
                  <td class="pe-4 py-3 text-end">
                    <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2">
                      <%= device.status_i18n %>
                    </span>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="3" class="text-center py-5 text-muted">
                  <p class="text-muted mb-0">登録した機器はありません。</p>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  
    <% # 未承認申請一覧を表示 %>
    <div class="d-flex justify-content-between align-items-center mb-3 mt-3">
      <h2 class="h4 mb-0 text-secondary fw-bold">未承認申請一覧</h2>
    </div>

    <div class="card shadow-sm border-0 overflow-hidden">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4 border-0 py-3">申請ID</th>
              <th class="border-0 py-3">申請者</th>
              <th class="pe-4 border-0 py-3 text-end">ステータス</th>
            </tr>
          </thead>
          <tbody>
            <% if @pending_requests.present? %>
              <% @pending_requests.each do |req| %>
                <tr>
                  <td class="ps-4 py-3">
                    <span class="fw-medium"><%= link_to req.id, show_pending_request_path(req), class: "text-decoration-none" %></span>
                  </td>
                  <td class="py-3">
                    <span class="fw-medium"><%= req.user.name %></span>
                  </td>
                  <td class="pe-4 py-3 text-end">
                    <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2">
                    <%= req.status_i18n %>
                    </span>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="3" class="text-center py-5 text-muted">
                  <p class="text-muted mb-0">未承認の申請はありません。</p>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <% # 承認履歴を表示 %>
    <div class="d-flex justify-content-between align-items-center mb-3 mt-3">
      <h2 class="h4 mb-0 text-secondary fw-bold">承認履歴</h2>
    </div>

    <div class="card shadow-sm border-0 overflow-hidden">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4 border-0 py-3">申請ID</th>
              <th class="border-0 py-3">申請者</th>
              <th class="pe-4 border-0 py-3 text-end">ステータス</th>
            </tr>
          </thead>
          <tbody>
            <% if @requests_history.present? %>
              <% @requests_history.each do |req| %>
                <tr>
                  <td class="ps-4 py-3">
                    <span class="fw-medium"><%= link_to req.id, show_history_request_path(req), class: "text-decoration-none" %></span>
                  </td>
                  <td class="py-3">
                    <span class="fw-medium"><%= req.user.name %></span>
                  </td>
                  <td class="pe-4 py-3 text-end">
                    <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2">
                    <%= req.status_i18n %>
                    </span>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="3" class="text-center py-5 text-muted">
                  <p class="text-muted mb-0">承認履歴はありません。</p>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    
    <% # 申請履歴を表示 %>
    <%= render "shared/request_history" %>

  
  <% # 一般ユーザー表示メニュー%>  
  <% else %>
    <% # 申請履歴を表示 %>
    <%= render "shared/request_history" %>
  <% end %>
</div>